---
import Base from '../layouts/Base.astro';
---

<Base
  title="Brand Images — Eidos AGI"
  description="Brand images for Substack, social, and profiles."
>
    <article class="prose-page">
      <header class="page-hero">
        <h1>Brand Images</h1>
        <p class="subtitle">Right-click to save.</p>
      </header>

      <section class="content-section">
        <h2>Personal (Substack / Social)</h2>
        <div class="img-stack">
          <div class="img-item">
            <img src="/substack-profile.png" alt="Substack profile" width="200" height="200" />
            <span>800x800 — Profile with photo + hook text</span>
          </div>
          <div class="img-item">
            <img src="/substack-profile-400.png" alt="Profile 400" width="200" height="200" />
            <span>400x400 — Medium profile</span>
          </div>
          <div class="img-item">
            <img src="/substack-profile-256.png" alt="Profile 256" width="128" height="128" />
            <span>256x256 — Substack publication logo</span>
          </div>
          <div class="img-item">
            <img src="/substack-cover.png" alt="Substack cover" width="550" height="110" />
            <span>1100x220 — Substack cover banner</span>
          </div>
          <div class="img-item">
            <img src="/substack-header.png" alt="Header 1500x500" width="600" height="200" />
            <span>1500x500 — Twitter/X header</span>
          </div>
          <div class="img-item">
            <img src="/substack-og.png" alt="OG 1200x630" width="600" height="315" />
            <span>1200x630 — Social share preview</span>
          </div>
        </div>
      </section>

      <section class="content-section">
        <h2>Eidos AGI (Org)</h2>
        <div class="img-stack">
          <div class="img-item">
            <img src="/logo-800.png" alt="Logo 800" width="200" height="200" />
            <span>800x800 — Org logo (GitHub, PyPI)</span>
          </div>
          <div class="img-item">
            <img src="/logo-256.png" alt="Logo 256" width="128" height="128" />
            <span>256x256 — Small org logo</span>
          </div>
          <div class="img-item">
            <img src="/og.png" alt="OG image" width="600" height="315" />
            <span>1200x630 — Org OG image (social share)</span>
          </div>
          <div class="img-item">
            <img src="/banner-1100x220.png" alt="Banner" width="550" height="110" />
            <span>1100x220 — Org banner</span>
          </div>
          <div class="img-item">
            <img src="/header-1500x500.png" alt="Header" width="600" height="200" />
            <span>1500x500 — Org Twitter/X header</span>
          </div>
        </div>
      </section>
    </article>
</Base>

<style is:global>
  .img-grid { display: flex; gap: var(--space-6); flex-wrap: wrap; align-items: flex-end; margin-top: var(--space-4); }
  .img-stack { display: flex; flex-direction: column; gap: var(--space-6); margin-top: var(--space-4); }
  .img-item { display: flex; flex-direction: column; gap: var(--space-2); }
  .img-item img { border: var(--border-width) solid color-mix(in srgb, var(--color-muted) 20%, transparent); border-radius: var(--radius-md); }
  .img-item span { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); }
</style>
