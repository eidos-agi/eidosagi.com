---
import Base from '../../layouts/Base.astro';
import { getGitHubStars, getPyPIDownloads, getPyPIInfo } from '../../lib/stats';

const tools = [
  { name: 'visionlog', pip: 'visionlog-md', repo: 'visionlog.md', role: 'Governance', desc: 'Vision, goals, guardrails, ADRs.' },
  { name: 'research.md', pip: 'research-md', repo: 'research.md', role: 'Decisions', desc: 'Evidence-graded, phase-gated, peer-reviewed.' },
  { name: 'ike.md', pip: 'ike-md', repo: 'ike.md', role: 'Execution', desc: 'Tasks, milestones, Definition of Done.' },
  { name: 'railguey', pip: 'railguey', repo: 'railguey', role: 'MCP', desc: 'Railway deployment management.' },
  { name: 'clawdflare', pip: 'clawdflare', repo: 'clawdflare', role: 'MCP', desc: 'Cloudflare zone auditing.' },
  { name: 'eidos-mcp-registry', pip: 'eidos-mcp-registry', repo: 'eidos-mcp-registry', role: 'MCP', desc: 'MCP server scoping.' },
  { name: 'resume-resume', pip: 'resume-resume', repo: 'resume-resume', role: 'Agent', desc: 'Post-crash session recovery.' },
  { name: 'apple-a-day', pip: 'apple-a-day', repo: 'apple-a-day', role: 'Agent', desc: 'Mac health. Zero deps.' },
];

const stats = await Promise.all(tools.map(async t => {
  const [downloads, info] = await Promise.all([
    getPyPIDownloads(t.pip),
    getPyPIInfo(t.pip),
  ]);
  return { ...t, downloads, version: info?.version, released: info?.releaseDate };
}));
---

<Base
  title="Tools — Eidos AGI"
  description="9 open-source packages for AI agent governance, decisions, and execution. All MIT. All pip installable."
>
    <header class="tools-hero">
      <h1>Tools</h1>
      <p>9 packages on PyPI. All open source. All MIT.</p>
    </header>

    <div class="tools-list">
      {stats.map(t => (
        <a href={`/tools/${t.name === 'research.md' ? 'research' : t.name === 'ike.md' ? 'ike' : t.name}`} class="tl-row">
          <span class="tl-role">{t.role}</span>
          <span class="tl-name">{t.name}</span>
          <span class="tl-desc">{t.desc}</span>
          <code class="tl-pip">pip install {t.pip}</code>
          <span class="tl-meta">
            {t.version && <span>v{t.version}</span>}
            {t.downloads > 0 && <span>{t.downloads.toLocaleString()}/mo</span>}
          </span>
        </a>
      ))}
    </div>
</Base>

<style is:global>
  .tools-hero { padding: var(--space-16) 0 var(--space-8); }
  .tools-hero h1 { margin-bottom: var(--space-3); }
  .tools-hero p { color: var(--color-muted); }

  .tools-list {
    display: flex;
    flex-direction: column;
    border-top: var(--border-width) solid color-mix(in srgb, var(--color-muted) 15%, transparent);
  }

  .tl-row {
    display: grid;
    grid-template-columns: 80px 180px 1fr auto auto;
    gap: var(--space-4);
    align-items: baseline;
    padding: var(--space-4) 0;
    border-bottom: var(--border-width) solid color-mix(in srgb, var(--color-muted) 10%, transparent);
    text-decoration: none;
    transition: background 150ms ease;
  }
  .tl-row:hover { background: color-mix(in srgb, var(--color-surface) 50%, transparent); }

  .tl-role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-secondary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .tl-name {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }
  .tl-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .tl-pip {
    font-size: var(--text-xs);
    color: var(--color-command);
    white-space: nowrap;
  }
  .tl-meta {
    display: flex;
    gap: var(--space-3);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
  }

  @media (max-width: 768px) {
    .tl-row { grid-template-columns: 1fr; gap: var(--space-1); }
    .tl-pip, .tl-meta { display: none; }
  }
</style>
