</Base>

<style is:global>
  .mvd-compare { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); margin: var(--space-6) 0; }
  .mvd-compare-item { background: var(--color-surface); border-radius: var(--radius-md); overflow: hidden; }
  .mvd-compare-header { font-family: var(--font-mono); font-size: var(--text-xs); padding: var(--space-3) var(--space-4); font-weight: 500; }
  .mvd-product .mvd-compare-header { background: color-mix(in srgb, var(--color-danger) 12%, transparent); color: var(--color-danger); }
  .mvd-data .mvd-compare-header { background: color-mix(in srgb, var(--color-command) 12%, transparent); color: var(--color-command); }
  .mvd-compare-item ul { list-style: none; padding: var(--space-4); margin: 0; }
  .mvd-compare-item li { font-size: var(--text-sm); color: var(--color-muted); padding: var(--space-1) 0; line-height: var(--leading-normal); }
  .mvd-parts { padding-left: var(--space-6); }
  .mvd-parts li { font-size: var(--text-sm); color: var(--color-muted); padding: var(--space-2) 0; line-height: var(--leading-normal); }
  .mvd-steps { padding-left: var(--space-6); }
  .mvd-steps li { font-size: var(--text-sm); color: var(--color-muted); padding: var(--space-2) 0; line-height: var(--leading-normal); }
  .mvd-closing { font-size: var(--text-md); line-height: var(--leading-relaxed); }
  .mvd-evidence { display: grid; grid-template-columns: 1fr; gap: var(--space-4); margin: var(--space-6) 0; }
  .mvd-evidence-item { background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-5) var(--space-6); border-left: 3px solid var(--color-primary); }
  .mvd-evidence-item h3 { font-size: var(--text-base); color: var(--color-text); margin-bottom: var(--space-2); }
  .mvd-evidence-item p { font-size: var(--text-sm); color: var(--color-muted); line-height: var(--leading-relaxed); margin-bottom: var(--space-3); }
  .mvd-evidence-item cite { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); opacity: 0.6; font-style: normal; display: block; }
  @media (max-width: 768px) { .mvd-compare { grid-template-columns: 1fr; } }
</style>
