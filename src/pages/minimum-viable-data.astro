  .mvd-evidence-item p { font-size: var(--text-sm); color: var(--color-muted); line-height: var(--leading-relaxed); margin-bottom: var(--space-3); }
  .mvd-evidence-item cite { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); opacity: 0.6; font-style: normal; display: block; }
