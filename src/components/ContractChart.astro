---
interface Props {
  contractLabel: string;
  outputLabel: string;
  arrowText?: string;
  skillLabel?: string;
  skillMeta?: string;
}
const { contractLabel, outputLabel, arrowText = 'produces', skillLabel, skillMeta } = Astro.props;
---

<div class="chart">
  <div class="chart-col">
    <div class="chart-header">{ contractLabel }</div>
    <div class="chart-body">
      <slot name="contract" />
    </div>
  </div>
  <div class="chart-arrow">{ arrowText }</div>
  <div class="chart-col">
    <div class="chart-header">{ outputLabel }</div>
    <div class="chart-body">
      <slot name="output" />
    </div>
  </div>
</div>

{skillLabel && (
  <div class="chart-skill">
    <div class="chart-skill-header">{skillLabel} {skillMeta && <span class="chart-skill-meta">{skillMeta}</span>}</div>
    <div class="chart-skill-body">
      <slot name="skill" />
    </div>
  </div>
)}

<style>
  .chart { display: grid; grid-template-columns: 1fr auto 1fr; gap: var(--space-3); align-items: start; margin: var(--space-6) 0; }
  .chart-col { background: var(--color-surface); border-radius: var(--radius-md); overflow: hidden; }
  .chart-header { font-family: var(--font-mono); font-size: var(--text-xs); padding: var(--space-2) var(--space-4); background: color-mix(in srgb, var(--color-command) 15%, transparent); color: var(--color-command); font-weight: 500; }
  .chart-arrow { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); padding-top: var(--space-8); text-align: center; }
  .chart-body { padding: var(--space-4); }
  .chart-body :global(pre) { margin: 0; }
  .chart-body :global(code) { font-size: 11px; color: var(--color-muted); line-height: 1.6; }
  .chart-skill { background: var(--color-surface); border-radius: var(--radius-md); overflow: hidden; margin-top: var(--space-3); opacity: 0.6; }
  .chart-skill-header { font-family: var(--font-mono); font-size: var(--text-xs); padding: var(--space-2) var(--space-4); background: color-mix(in srgb, var(--color-danger) 10%, transparent); color: var(--color-danger); font-weight: 500; }
  .chart-skill-meta { opacity: 0.5; margin-left: var(--space-2); }
  .chart-skill-body { padding: var(--space-4); }
  .chart-skill-body :global(pre) { margin: 0; }
  .chart-skill-body :global(code) { font-size: 11px; color: var(--color-muted); line-height: 1.6; }
  @media (max-width: 768px) { .chart { grid-template-columns: 1fr; } .chart-arrow { padding: var(--space-2) 0; } }
</style>
