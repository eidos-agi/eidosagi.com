---
interface Props {
  items: string[];
}
const { items } = Astro.props;
---

<div class="pills">
  {items.map(item => (
    <span class="pill">{item}</span>
  ))}
</div>

<style>
  .pills { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .pill { font-family: var(--font-mono); font-size: 10px; color: var(--color-primary); background: color-mix(in srgb, var(--color-primary) 8%, transparent); padding: 2px 8px; border-radius: 3px; }
</style>
