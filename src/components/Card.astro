---
interface Props {
  href?: string;
  badge?: string;
  badgeVariant?: 'command' | 'muted';
  bordered?: boolean;
}
const { href, badge, badgeVariant = 'command', bordered = false } = Astro.props;
const Tag = href ? 'a' : 'div';
---

<Tag href={href} class:list={['card', { 'card-bordered': bordered, 'card-link': !!href }]}>
  {badge && <span class={`card-badge card-badge-${badgeVariant}`}>{badge}</span>}
  <slot />
</Tag>

<style>
  .card { display: block; background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-6); position: relative; text-decoration: none; border: var(--border-width) solid color-mix(in srgb, var(--color-muted) 12%, transparent); }
  .card-bordered { border-color: color-mix(in srgb, var(--color-command) 25%, transparent); }
  .card-link { transition: transform 0.15s ease; cursor: pointer; }
  .card-link:hover { transform: translateY(-2px); }
  .card-badge { position: absolute; top: var(--space-4); right: var(--space-4); font-family: var(--font-mono); font-size: var(--text-xs); padding: 2px 10px; border-radius: 3px; z-index: 1; }
  .card-badge-command { color: var(--color-command); background: color-mix(in srgb, var(--color-command) 12%, transparent); }
  .card-badge-muted { color: var(--color-muted); background: color-mix(in srgb, var(--color-muted) 10%, transparent); }
  .card :global(h2), .card :global(h3) { color: var(--color-text); margin-bottom: var(--space-2); }
  .card :global(p) { font-size: var(--text-sm); color: var(--color-muted); line-height: var(--leading-normal); margin-bottom: var(--space-3); }
</style>
