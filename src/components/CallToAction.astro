---
interface Props {
  href: string;
  label: string;
  detail?: string;
}
const { href, label, detail } = Astro.props;
---

<div class="cta">
  <a href={href} class="cta-btn">{label}</a>
  {detail && <p class="cta-detail">{detail}</p>}
  <slot />
</div>

<style>
  .cta { text-align: center; margin: var(--space-8) 0; padding: var(--space-8) var(--space-6); background: var(--color-surface); border-radius: var(--radius-md); border: var(--border-width) solid color-mix(in srgb, var(--color-muted) 8%, transparent); }
  .cta-btn { display: inline-block; font-family: var(--font-mono); font-size: var(--text-sm); color: var(--color-bg); background: var(--color-text); padding: var(--space-3) var(--space-8); border-radius: var(--radius-md); text-decoration: none; font-weight: 500; letter-spacing: 0.02em; transition: opacity 0.15s; }
  .cta-btn:hover { opacity: 0.8; }
  .cta-detail { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--color-muted); margin-top: var(--space-4); }
</style>
