---
interface Props {
  title: string;
  cite?: string;
}
const { title, cite } = Astro.props;
---

<div class="evidence">
  <h3>{title}</h3>
  <div class="evidence-body">
    <slot />
  </div>
  {cite && <cite>{cite}</cite>}
</div>

<style>
  .evidence { background: var(--color-surface); border-radius: var(--radius-md); padding: var(--space-6); border-left: 3px solid color-mix(in srgb, var(--color-primary) 50%, transparent); }
  h3 { font-size: var(--text-sm); font-weight: var(--weight-medium); color: var(--color-text); margin-bottom: var(--space-3); letter-spacing: -0.01em; }
  .evidence-body :global(p) { font-size: var(--text-sm); color: var(--color-muted); line-height: var(--leading-relaxed); margin-bottom: var(--space-3); }
  .evidence-body :global(p:last-child) { margin-bottom: var(--space-4); }
  cite { font-family: var(--font-mono); font-size: 10px; color: var(--color-muted); opacity: 0.5; font-style: normal; display: block; line-height: var(--leading-relaxed); }
</style>
