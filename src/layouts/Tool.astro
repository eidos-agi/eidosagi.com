---
import Base from './Base.astro';
import { getGitHubStars, getPyPIDownloads, getPyPIInfo } from '../lib/stats';

interface Props {
  name: string;
  pip: string;
  role: string;
  repo: string;
  description: string;
}

const { name, pip, role, repo, description } = Astro.props;
const pipPkg = pip.replace('pip install ', '');
const [stars, downloads, pypiInfo] = await Promise.all([
  getGitHubStars(repo),
  getPyPIDownloads(pipPkg),
  getPyPIInfo(pipPkg),
]);
---

<Base
  title={`${name} — Eidos AGI`}
  description={description}
>
    <span class="tool-role-badge">{role}</span>
    <header class="tool-hero">
      <h1>{name}</h1>
      <p class="tool-desc">{description}</p>
      <div class="tool-actions">
        <code class="tool-pip">{pip}</code>
        <a href={`https://github.com/eidos-agi/${repo}`} class="tool-gh">View on GitHub</a>
        {stars > 0 && <span class="tool-badge">{stars} stars</span>}
        {downloads > 0 && <span class="tool-badge">{downloads.toLocaleString()} downloads/mo</span>}
        {pypiInfo && <span class="tool-badge">v{pypiInfo.version}</span>}
        {pypiInfo?.releaseDate && <span class="tool-badge">{pypiInfo.releaseDate}</span>}
      </div>
    </header>

    <div class="tool-content">
      <slot />
    </div>

  <script>
    // Copy buttons
    document.querySelectorAll('.tool-content pre').forEach(pre => {
      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.textContent = 'Copy';
      btn.setAttribute('aria-label', 'Copy code to clipboard');
      btn.addEventListener('click', () => {
        const code = pre.querySelector('code');
        if (code) {
          navigator.clipboard.writeText(code.textContent || '').then(() => {
            btn.textContent = 'Copied';
            setTimeout(() => { btn.textContent = 'Copy'; }, 1500);
          });
        }
      });
      pre.style.position = 'relative';
      pre.appendChild(btn);
    });
  </script>
</Base>

<style is:global>
  .tool-role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .tool-hero {
    padding: var(--space-16) 0 var(--space-12);
    border-bottom: var(--border-width) solid color-mix(in srgb, var(--color-muted) 20%, transparent);
  }
  .tool-hero h1 {
    font-size: clamp(2rem, 5vw, var(--text-4xl));
    margin-bottom: var(--space-4);
  }
  .tool-desc {
    font-size: var(--text-lg);
    color: var(--color-muted);
    max-width: var(--measure-prose);
    margin-bottom: var(--space-8);
  }
  .tool-actions {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }
  .tool-pip {
    font-size: var(--text-base);
    color: var(--color-command);
    background: var(--color-surface);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    border: var(--border-width) solid color-mix(in srgb, var(--color-muted) 15%, transparent);
  }
  .tool-gh {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }
  .tool-badge {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-secondary);
    border: var(--border-width) solid color-mix(in srgb, var(--color-secondary) 30%, transparent);
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
  }

  .tool-content {
    padding: var(--space-12) 0;
  }
  .tool-content h2 {
    margin-bottom: var(--space-4);
    padding-top: var(--space-8);
  }
  .tool-content h2:first-child { padding-top: 0; }
  .tool-content p {
    max-width: var(--measure-prose);
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
  }
  .tool-content ul, .tool-content ol {
    padding-left: var(--space-6);
    margin-bottom: var(--space-6);
    max-width: var(--measure-prose);
  }
  .tool-content li {
    margin-bottom: var(--space-2);
    line-height: var(--leading-relaxed);
  }
  .tool-diagram { margin: var(--space-8) 0; max-width: 420px; }
  .tool-diagram svg { width: 100%; height: auto; }
  .tool-content pre {
    margin-bottom: var(--space-6);
    max-width: 100%;
    position: relative;
  }
  .copy-btn {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-muted);
    background: var(--color-bg);
    border: var(--border-width) solid color-mix(in srgb, var(--color-muted) 20%, transparent);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-2);
    cursor: pointer;
    opacity: 0;
    transition: opacity 150ms ease, color 150ms ease;
  }
  pre:hover .copy-btn { opacity: 1; }
  .copy-btn:hover { color: var(--color-primary); border-color: var(--color-primary); }

  @media (max-width: 768px) {
    .tool-hero { padding-top: var(--space-8); }
    .tool-hero h1 { font-size: var(--text-2xl); }
    .tool-actions { flex-direction: column; align-items: flex-start; }
    .tool-pip { font-size: var(--text-sm); overflow-x: auto; max-width: 100%; }
    .tool-content pre { font-size: var(--text-xs); }
    .page { padding: 0 var(--space-4); }
  }
</style>
