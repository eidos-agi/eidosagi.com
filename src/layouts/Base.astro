---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, 'https://eidosagi.com');
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content="https://eidosagi.com/og.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://eidosagi.com/og.png" />
    <link rel="canonical" href={canonicalURL.href} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <link rel="preload" href="/fonts/SpaceGrotesk-latin.woff2" as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
    <script is:inline>
      (function() {
        var t = localStorage.getItem('eidos-theme');
        if (t && t !== 'workshop') document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body>
    <div class="page">
      <div class="mark">
        <a href="/">eidos agi</a>
        <div class="mark-right">
          <div class="theme-switcher">
            <button class="theme-dot" data-set-theme="workshop" style="background:#c4935a" title="Workshop"></button>
            <button class="theme-dot" data-set-theme="midnight" style="background:#6c8aff" title="Midnight"></button>
            <button class="theme-dot" data-set-theme="forest" style="background:#4ade80" title="Forest"></button>
            <button class="theme-dot" data-set-theme="copper" style="background:#e88a48" title="Copper"></button>
            <button class="theme-dot" data-set-theme="paper" style="background:#f0ebe4;border:1px solid #8a8078" title="Paper"></button>
            <button class="theme-dot" data-set-theme="slate" style="background:#a78bfa" title="Slate"></button>
            <button class="theme-dot theme-ai" data-set-theme="ai" title="AI Reader Mode">AI</button>
          </div>
          <nav id="nav-menu">
            <a href="/eidos">eidos</a>
            <a href="/trilogy">trilogy</a>
            <a href="/tools">tools</a>
            <a href="/forges">forges</a>
            <a href="https://github.com/eidos-agi">github</a>
          </nav>
          <button class="hamburger" id="hamburger" aria-label="Menu" aria-expanded="false" aria-controls="nav-menu">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <line x1="3" y1="5" x2="17" y2="5"/>
              <line x1="3" y1="10" x2="17" y2="10"/>
              <line x1="3" y1="15" x2="17" y2="15"/>
            </svg>
          </button>
        </div>
      </div>

      <slot />

      <footer class="foot">
        <div class="foot-top">
          <div class="foot-col">
            <span class="foot-heading">Shipped</span>
            <a href="/trilogy">Trilogy</a>
            <a href="/tools">Tools</a>
            <a href="/forges">Forges</a>
            <a href="/contract-driven-development">Contracts</a>
          </div>
          <div class="foot-col">
            <span class="foot-heading">In Development</span>
            <a href="/eidos">Eidos</a>
            <a href="/agent-identity">Identity</a>
            <a href="/memory">Memory</a>
          </div>
          <div class="foot-col">
            <span class="foot-heading">Links</span>
            <a href="/about">About</a>
            <a href="https://github.com/eidos-agi">GitHub</a>
            <a href="https://pypi.org/user/eidos-agi/">PyPI</a>
          </div>
        </div>
        <span class="foot-copy">&copy; {new Date().getFullYear()} Eidos AGI</span>
      </footer>
    </div>

    <script>
      // Theme switcher
      const saved = localStorage.getItem('eidos-theme');
      document.querySelectorAll('[data-set-theme]').forEach(btn => {
        if ((btn as HTMLElement).dataset.setTheme === (saved || 'workshop')) btn.classList.add('active');
        btn.addEventListener('click', () => {
          const theme = (btn as HTMLElement).dataset.setTheme!;
          if (theme === 'workshop') {
            document.documentElement.removeAttribute('data-theme');
          } else {
            document.documentElement.setAttribute('data-theme', theme);
          }
          localStorage.setItem('eidos-theme', theme);
          document.querySelectorAll('[data-set-theme]').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
        });
      });

      // Hamburger
      const hb = document.getElementById('hamburger');
      const nm = document.getElementById('nav-menu');
      if (hb && nm) {
        hb.addEventListener('click', () => {
          nm.classList.toggle('open');
          hb.setAttribute('aria-expanded', String(nm.classList.contains('open')));
        });
        document.addEventListener('click', (e) => {
          if (!hb.contains(e.target as Node) && !nm.contains(e.target as Node)) nm.classList.remove('open');
        });
      }
    </script>
  </body>
</html>
